# Ochrana tmp adresára
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^tmp/ - [F,L]
</IfModule>

# Nekešovať HTML — aby sa vždy načítala aktuálna verzia formulárov
<IfModule mod_headers.c>
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>
